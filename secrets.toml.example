# ExamHelp AI — secrets.toml template
# Place your NEW keys here after revoking exposed ones
# NEVER commit this file to git

# [groq]
# api_keys = ["YOUR_NEW_GROQ_KEY_HERE"]

# [gemini]
# api_keys = ["YOUR_NEW_GEMINI_KEY_HERE"]

# ALL OTHER INTEGRATIONS (Supabase, Stripe, Google, Cloudflare) REMOVED

# ── Optional API Keys (all free) ──────────────────────────────────────────────
# YouTube Data API v3 (https://console.cloud.google.com)
# YOUTUBE_API_KEY = "your_youtube_api_key_here"

# GNews API (https://gnews.io) — free 100 req/day
# GNEWS_API_KEY = "your_gnews_key_here"

# NewsData.io (https://newsdata.io) — free 200 req/day
# NEWSDATA_API_KEY = "your_newsdata_key_here"

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Scope: public_repo — raises limit from 60 to 5000 req/hr
# GITHUB_TOKEN = "github_pat_your_token_here"
