# ExamHelp AI — .env Template v3.1
# NEVER commit .env to git

# ── Groq / Gemini (existing) ──────────────────────────────
GROQ_API_KEY_1=gsk_your_first_groq_key_here
GROQ_API_KEY_2=gsk_your_second_groq_key_here
GEMINI_API_KEY_1=AIzaSy_your_first_gemini_key_here

# ── Supabase Auth ─────────────────────────────────────────
# Create project at https://supabase.com
# Settings → API → URL + anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...your_anon_key_here
SUPABASE_REDIRECT_URL=https://your-app.streamlit.app

# ── Google OAuth (Gmail / Drive / Calendar / Maps) ────────
# GCP Console → OAuth 2.0 Client ID (Web)
# Enable: Gmail API, Drive API, Calendar API, Maps Embed API
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret
GOOGLE_REDIRECT_URI=https://your-app.streamlit.app
GOOGLE_MAPS_EMBED_KEY=your_maps_embed_key

# ── Stripe Payments ───────────────────────────────────────
# dashboard.stripe.com → API keys + create Pro product
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_monthly_id_here
STRIPE_ANNUAL_PRICE_ID=price_annual_id_here
STRIPE_SUCCESS_URL=https://your-app.streamlit.app?payment=success
STRIPE_CANCEL_URL=https://your-app.streamlit.app?payment=cancel

# ── Other service keys (existing) ─────────────────────────
GNEWS_API_KEY=your_gnews_key
NEWSDATA_API_KEY=your_newsdata_key
PIXABAY_API_KEY=your_pixabay_key
PEXELS_API_KEY=your_pexels_key
