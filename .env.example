# ============================================================
#  ExamHelp AI — Environment Variables Template
#  Copy this to .env and fill in your real keys.
#  NEVER commit .env to git — it is gitignored.
# ============================================================

# ── Groq API Keys (LLM backbone) ──────────────────────────
# Free at: https://console.groq.com  |  Rotate up to 12 keys
GROQ_API_KEY_1=gsk_your_first_groq_key_here
GROQ_API_KEY_2=gsk_your_second_groq_key_here
# GROQ_API_KEY_3=gsk_...
# GROQ_API_KEY_4=gsk_...
# GROQ_API_KEY_5=gsk_...
# GROQ_API_KEY_6=gsk_...
# GROQ_API_KEY_7=gsk_...
# GROQ_API_KEY_8=gsk_...
# GROQ_API_KEY_9=gsk_...
# GROQ_API_KEY_10=gsk_...
# GROQ_API_KEY_11=gsk_...
# GROQ_API_KEY_12=gsk_...

# ── Gemini API Keys (vision + extra capacity) ─────────────
# Free at: https://aistudio.google.com/app/apikey  |  Up to 7 keys
GEMINI_API_KEY_1=AIzaSy_your_first_gemini_key_here
GEMINI_API_KEY_2=AIzaSy_your_second_gemini_key_here
# GEMINI_API_KEY_3=AIzaSy_...
# GEMINI_API_KEY_4=AIzaSy_...
# GEMINI_API_KEY_5=AIzaSy_...
# GEMINI_API_KEY_6=AIzaSy_...
# GEMINI_API_KEY_7=AIzaSy_...

# ── Optional extras ───────────────────────────────────────
# PEXELS_API_KEY=your_pexels_key_here
# PIXABAY_API_KEY=your_pixabay_key_here

# ── Dedicated Code Debugger Keys (HIGHEST tier Gemini) ────
# These are EXCLUSIVELY for Code Debugger + Learn Coding.
# Uses gemini-2.5-flash-preview — most capable model.
# Get separate keys from different GCP projects for max quota.
# GEMINI_DEBUG_KEY_1=AIzaSy_debug_key_1_here
# GEMINI_DEBUG_KEY_2=AIzaSy_debug_key_2_here
# GEMINI_DEBUG_KEY_3=AIzaSy_debug_key_3_here
# GEMINI_DEBUG_KEY_4=AIzaSy_debug_key_4_here
# GEMINI_DEBUG_KEY_5=AIzaSy_debug_key_5_here

# ── Service API Keys ─────────────────────────────────────
# Google Maps Embed (for campus map + trip planner)
# GOOGLE_MAPS_EMBED_KEY=your_google_maps_embed_key_here

# GNews API (for AI News Hub — free at gnews.io)
# GNEWS_API_KEY=your_gnews_api_key_here

# NewsData API (fallback news — free at newsdata.io)
# NEWSDATA_API_KEY=your_newsdata_api_key_here

# Pixabay (free image search — get at pixabay.com/api)
# PIXABAY_API_KEY=your_pixabay_key_here

# Pexels (premium image search — get at pexels.com/api)
# PEXELS_API_KEY=your_pexels_key_here
